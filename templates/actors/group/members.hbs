<section data-group="{{ tab.group }}" data-tab="{{ tab.id }}" class="tab {{ tab.cssClass }} flex1">
    <header class="team-header">
        <div>
            <h2 class="roboto-upper">{{ localize "SHMN.Team.Title" }}</h2>
            <p>{{ localize "SHMN.Team.Lineup" }}</p>
        </div>
        <button
            type="button"
            class="gold-button always-interactive team-contest-action"
            data-action="teamContest"
            data-tooltip="SHMN.TeamContest.Action.Start"
            aria-label="{{ localize "SHMN.TeamContest.Action.Start" }}">
            <i class="fa-solid fa-dice-d6" inert></i>
        </button>
    </header>

    {{#each sections}}
    <section class="team-section team-section-{{ key }}" data-role="{{ key }}">
        <h3 class="sabers roboto-upper">
            {{ localize label }}
            {{#if capacity}}<span>{{ members.length }}/{{ capacity }}</span>{{/if}}
        </h3>
        <menu class="members {{#if hasStats}}stats{{/if}}">
            {{#each members}}
            {{> "systems/shmn/templates/actors/group/member.hbs" section=.. }}
            {{/each}}
            {{#each emptySlots}}
            <li class="member team-empty-slot" data-role="{{ ../key }}">
                <div class="vitals card">
                    <div class="portrait"><i class="fa-solid fa-user-plus" inert></i></div>
                    <div class="bars">
                        <strong class="name">{{ localize "SHMN.Team.EmptySlot" }}</strong>
                    </div>
                </div>
            </li>
            {{/each}}
        </menu>
    </section>
    {{/each}}
</section>
