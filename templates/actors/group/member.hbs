<li class="member role-{{ role }} {{#if @root.editable}}draggable{{/if}}" data-uuid="{{ uuid }}" data-actor-id="{{ id }}">
    {{#if @root.editable}}
    <input type="hidden" name="system.members.{{ index }}.actor" value="{{ id }}">
    <input type="hidden" name="system.members.{{ index }}.role" value="{{ role }}">
    {{#unless canManageGoals}}
    <input type="hidden" name="system.members.{{ index }}.goals" value="{{ goals }}" data-dtype="Number">
    {{/unless}}
    {{/if}}
    <div class="vitals card" {{#if underlay}}style="--underlay: {{ underlay }}"{{/if}}>
        {{#if isPrimaryVehicle}}
        <i class="fa-duotone fa-solid fa-circle-star primary-vehicle" data-tooltip
           aria-label="{{ localize "SHMN.Group.Vehicle.Primary.label" }}"></i>
        {{/if}}
        <div class="portrait">
            {{#if portrait.isVideo}}
            <video src="{{ portrait.src }}" autoplay muted playsinline disablepictureinpicture loop></video>
            {{else}}
            <img src="{{ portrait.src }}" alt="{{ name }}">
            {{/if}}
        </div>
        <div class="bars">
            <strong class="name">
                <a {{#if canView}}data-action="showDocument"{{/if}} data-uuid="{{ uuid }}">
                    {{ name }}
                </a>
            </strong>
            {{#with stamina}}
            <div class="stamina-bar bar">
                <label>{{ localize "SHMN.Stamina" }}</label>
                <div class="meter hit-points stamina-points progress" role="meter" aria-valuemin="0"
                     aria-valuenow="{{ value }}" aria-valuemax="{{ max }}"
                     style="--bar-percentage: {{ pct }}%"></div>
                <div class="values">
                    {{#unless ../hiddenStats}}
                    <span class="value">{{ value }}</span>
                    <span class="separator">&sol;</span>
                    <span class="max">{{ max }}</span>
                    {{/unless}}
                </div>
            </div>
            {{/with}}
            {{#if properties.length}}
            <ul class="pills">
                {{#each properties}}
                <li class="pill transparent">
                    <span class="label">{{ localize label }}</span>
                    <span class="separator">|</span>
                    <span class="value">{{ value }}</span>
                </li>
                {{/each}}
            </ul>
            {{/if}}
        </div>
        {{#if @root.editable}}
        <div class="classes controls">
            <select class="unselect team-role" data-action="changeMemberRole" data-actor-id="{{ id }}">
                {{ selectOptions @root.roleOptions selected=role localize=true }}
            </select>
            <button type="button" class="config-button unbutton" data-action="removeMember" data-tooltip
                    aria-label="{{ localize "SHMN.Group.Action.Remove" }}">
                <i class="fa-solid fa-square-xmark" inert></i>
            </button>
        </div>
        {{/if}}
    </div>
    {{#if section.hasStats}}
    <div class="stats">
        <div class="info team-stats">
            <div class="team-stat">
                {{#if teamSkill}}
                {{#if canRollTeamSkill}}
                <a class="{{ teamSkill.css }}" data-action="roll" data-type="skill" data-key="{{ teamSkill.key }}"
                   data-tooltip aria-label="{{ localize teamSkill.label }}">
                    <i class="fa-solid fa-people-group" inert></i>
                </a>
                {{else}}
                <i class="fa-solid fa-people-group" data-tooltip aria-label="{{ localize teamSkill.label }}"></i>
                {{/if}}
                <span class="label">{{ localize teamSkill.label }}</span>
                <span class="value">{{ shmn-formatModifier teamSkill.total }}</span>
                {{else}}
                <i class="fa-solid fa-people-group" inert></i>
                <span class="label">{{ localize "SHMN.Team.Role.Reserve" }}</span>
                <span class="value">&mdash;</span>
                {{/if}}
            </div>
            <div class="team-stat team-goals">
                <i class="fa-solid fa-futbol" data-tooltip aria-label="{{ localize "SHMN.Team.Goals" }}"></i>
                <span class="label">{{ localize "SHMN.Team.Goals" }}</span>
                <span class="value">
                    {{#if canManageGoals}}
                    <input type="text" class="uninput" name="system.members.{{ index }}.goals"
                           value="{{ goals }}" data-dtype="Number" inputmode="numeric" pattern="[+=\-]?\d*">
                    {{else}}
                    {{ shmn-numberFormat goals }}
                    {{/if}}
                </span>
            </div>
        </div>
    </div>
    {{/if}}
</li>
