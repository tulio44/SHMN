<section class="tab {{ tab.cssClass }}" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
    {{!-- Spellcasting --}}
    <section class="top">
        {{#each spellcasting}}
        <div class="spellcasting card {{#if primary}}primary{{/if}}" data-ability="{{ ability.ability }}">
            <div class="header">
                <h3>{{ label }}</h3>
                {{#if @root.isNPC}}
                {{#if (and @root.editable noSpellcaster)}}
                <select name="system.attributes.spellcasting">
                    {{ selectOptions @root.CONFIG.abilities selected=ability.ability labelAttr="label" blank="" }}
                </select>
                {{else}}
                <span class="spellcasting-ability subtitle">{{ ability.label }}</span>
                {{/if}}
                {{else}}
                <button type="button" class="radio-button" data-action="setSpellcastingAbility"
                    data-tooltip="SHMN.SpellAbilitySet" aria-pressed="{{#if primary}}true{{else}}false{{/if}}"
                    aria-label="{{ localize " SHMN.SpellAbilitySet" }}">
                </button>
                {{/if}}
            </div>

            <div class="info">
                <div class="ability">
                    <span class="label">{{ localize "SHMN.Ability" }}</span>
                    <span class="value">{{ shmn-formatModifier ability.mod }}</span>
                </div>

                <div class="attack">
                    <span class="label">{{ localize "SHMN.Attack" }}</span>
                    <span class="value">{{ shmn-formatModifier attack }}</span>
                </div>

                <div class="save">
                    <span class="label">{{ localize "SHMN.SpellDC" }}</span>
                    <span class="value">{{ save }}</span>
                </div>

                {{#if (or preparation.value preparation.max)}}
                <div class="prepared">
                    <span class="label">{{ localize "SHMN.Prepared" }}</span>
                    <span class="value {{#if preparation.max}}max-preparations{{/if}}">
                        <span class="count">{{ preparation.value }}</span>
                        {{#if preparation.max}}
                        <span class="separator">&sol;</span>
                        <span class="max">{{ preparation.max }}</span>
                        {{/if}}
                    </span>
                </div>
                {{/if}}

                {{#if @root.isNPC}}
                <div class="level">
                    <span class="label">{{ localize "SHMN.Level" }}</span>
                    {{#if (and @root.editable noSpellcaster)}}
                    {{ numberInput @root.system.attributes.spell.level name="system.attributes.spell.level" min=0 step=1
                    placeholder="—" }}
                    {{else}}
                    <span class="value">{{ level }}</span>
                    {{/if}}
                </div>

                <div class="concentration" data-ability="concentration">
                    <a class="label saving-throw {{ @root.rollableClass }}" data-action="roll" data-type="ability">
                        {{ localize "SHMN.Concentration" }}
                    </a>
                    {{#if @root.editable}}
                    <button type="button" class="config-button unbutton" data-action="showConfiguration"
                        data-config="ability" data-tooltip="{{ tooltip }}" aria-label="{{ tooltip }}">
                        <i class="fas fa-cog" inert></i>
                    </button>
                    {{else}}
                    <span class="value">{{ shmn-formatModifier concentration.mod }}</span>
                    {{/if}}
                </div>
                {{/if}}
            </div>
        </div>
        {{/each}}
    </section>

    {{!-- Spells by Pact --}}
    <section class="pactbook">
        {{#if @root.editable}}
        <header class="pactbook-header">
            <button type="button" class="config-button pact-create-button" data-action="createPact"
                data-tooltip="{{ localize " SHMN.PactCreate" }}" aria-label="{{ localize " SHMN.PactCreate" }}">
                <span class="pact-create-icon">
                    <i class="fas fa-handshake" inert></i>
                    <i class="fas fa-plus pact-create-plus" inert></i>
                </span>
            </button>
        </header>
        {{/if}}

        {{#each pactbook as |pact|}}
        <section class="pact card" data-pact-id="{{ pact.id }}">
            <div class="header pact-banner">
                {{#if @root.editable}}
                {{#unless pact.unlinked}}
                <img class="pact-img editable" src="{{ pact.img }}" alt="{{ pact.name }}" data-action="editPactImage"
                    data-pact-id="{{ pact.id }}">
                {{else}}
                <img class="pact-img" src="{{ pact.img }}" alt="{{ pact.name }}">
                {{/unless}}
                {{else}}
                <img class="pact-img" src="{{ pact.img }}" alt="{{ pact.name }}">
                {{/if}}

                <div class="pact-heading">
                    {{#if @root.editable}}
                    {{#unless pact.unlinked}}
                    <input type="text" class="pact-name-input" name="flags.shmn.pactsData.{{ pact.id }}.name"
                        value="{{ pact.name }}" placeholder="{{ localize " SHMN.Pact" }}">
                    {{else}}
                    <h3>{{ pact.name }}</h3>
                    {{/unless}}
                    {{else}}
                    <h3>{{ pact.name }}</h3>
                    {{/if}}

                    <span class="subtitle">{{ localize "SHMN.Pact" }}</span>
                </div>

                {{#if @root.editable}}
                {{#unless pact.unlinked}}
                <div class="pact-controls">
                    <button type="button" class="config-button unbutton" data-action="createPactSpell"
                        data-pact-id="{{ pact.id }}" data-tooltip="{{ localize " SHMN.PactSpellCreate" }}"
                        aria-label="{{ localize " SHMN.PactSpellCreate" }}">
                        <i class="fas fa-plus" inert></i>
                    </button>

                    <button type="button" class="config-button unbutton" data-action="deletePact"
                        data-pact-id="{{ pact.id }}" data-tooltip="{{ localize " SHMN.ContextMenuActionDelete" }}"
                        aria-label="{{ localize " SHMN.ContextMenuActionDelete" }}">
                        <i class="fas fa-trash" inert></i>
                    </button>
                </div>
                {{/unless}}
                {{/if}}
            </div>

            {{#if @root.editable}}
            <div class="pact-description">
                {{#unless pact.unlinked}}
                <prose-mirror name="flags.shmn.pactsData.{{ pact.id }}.description" value="{{ pact.description }}"
                    document-uuid="{{ @root.actor.uuid }}">
                </prose-mirror>
                {{/unless}}
            </div>
            {{else}}
            {{#if pact.description}}
            <div class="pact-description">
                <div class="editor">
                    <div class="editor-content pact-description-text">{{{ pact.description }}}</div>
                </div>
            </div>
            {{/if}}
            {{/if}}

            <div class="pact-spells">
                {{#if pact.rankGroups.length}}
                {{#each pact.rankGroups as |group|}}
                <section class="pact-rank-section" data-rank="{{ group.rank }}">
                    <div class="pact-rank-divider">
                        <span class="label">Rank {{ group.rank }}</span>
                    </div>

                    <shmn-inventory>
                        <div class="items-section">
                            <ol class="items-list spells-list unlist">
                                {{#each group.spells as |item|}}
                                {{#shmn-itemContext item as |ctx|}}
                                <li class="item collapsible {{#unless ctx.expanded}}collapsed{{/unless}}"
                                    data-item-id="{{ item.id }}" data-entry-id="{{ item.id }}"
                                    data-item-name="{{ item.name }}" data-item-sort="{{ item.sort }}"
                                    data-expand-id="{{ item.id }}" data-uuid="{{ item.uuid }}">

                                    <div class="item-row">
                                        <div class="item-name item-action item-tooltip rollable" data-action="edit"
                                            role="button" aria-label="{{ item.name }}">
                                            <div class="item-image gold-icon">
                                                <img src="{{ item.img }}" alt="{{ item.name }}">
                                            </div>

                                            <div class="name name-stacked">
                                                <span class="title">{{ item.name }}</span>
                                                {{#if ctx.subtitle}}
                                                <span class="subtitle">{{ ctx.subtitle }}</span>
                                                {{else}}
                                                <span class="subtitle"></span>
                                                {{/if}}
                                            </div>
                                        </div>

                                        <div class="item-detail item-controls">
                                            {{#if @root.editable}}
                                            <a class="item-control interface-only always-interactive"
                                                data-action="editPactSpell" data-item-id="{{ item.id }}"
                                                aria-label="{{ localize " SHMN.ContextMenuActionEdit" }}">
                                                <i class="fas fa-pen-to-square" inert></i>
                                            </a>

                                            <a class="item-control interface-only always-interactive"
                                                data-action="deletePactSpell" data-item-id="{{ item.id }}"
                                                aria-label="{{ localize " SHMN.ContextMenuActionDelete" }}">
                                                <i class="fas fa-trash" inert></i>
                                            </a>
                                            {{/if}}

                                            <a class="item-control item-action interface-only always-interactive"
                                                data-action="toggleExpand" data-toggle-description
                                                aria-label="{{ localize " SHMN.Description" }}">
                                                <i class="fa-solid {{#if ctx.expanded}}fa-compress{{else}}fa-expand{{/if}}"
                                                    inert></i>
                                            </a>

                                            <a class="item-control interface-only always-interactive" data-context-menu
                                                aria-label="{{ localize " SHMN.AdditionalControls" }}">
                                                <i class="fas fa-ellipsis-vertical" inert></i>
                                            </a>
                                        </div>
                                    </div>

                                    <div class="item-description collapsible-content">
                                        <div class="wrapper">
                                            {{> "shmn.item-summary" ctx.expanded }}
                                        </div>
                                    </div>
                                </li>
                                {{/shmn-itemContext}}
                                {{/each}}
                            </ol>
                        </div>
                    </shmn-inventory>
                </section>
                {{/each}}
                {{else}}
                <p class="empty">{{ localize "SHMN.None" }}</p>
                {{/if}}
            </div>
        </section>
        {{/each}}
    </section>
</section>