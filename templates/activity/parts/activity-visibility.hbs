<fieldset>
    <legend>{{ localize "SHMN.ACTIVITY.FIELDS.visibility.label" }}</legend>
    {{> "shmn.fieldlist" visibilityFields }}
    <div class="form-group">
        <label>{{ localize "SHMN.ACTIVITY.FIELDS.visibility.level.label" }}</label>
        <div class="form-fields range-fields">
            {{ formInput fields.visibility.fields.level.fields.min value=source.visibility.level.min
                         placeholder="0" ariaLabel=(localize "SHMN.LevelLimit.Min")
                         input=@root.inputs.createNumberInput }}
            <shmn-icon src="systems/shmn/icons/svg/range-connector.svg" class="sep"></shmn-icon>
            {{ formInput fields.visibility.fields.level.fields.max value=source.visibility.level.max
                         placeholder="∞" ariaLabel=(localize "SHMN.LevelLimit.Max")
                         input=@root.inputs.createNumberInput }}
        </div>
        <p class="hint">{{ localize "SHMN.ACTIVITY.FIELDS.visibility.level.hint" }}</p>
    </div>
    {{#if (or (not activity.isSpell) activity.isRider)}}
    {{ formField fields.visibility.fields.identifier value=source.visibility.identifier rootId=partId }}
    {{/if}}
</fieldset>
