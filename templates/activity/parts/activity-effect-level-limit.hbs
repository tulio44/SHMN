<div class="form-group">
    <label>{{ localize "SHMN.ACTIVITY.FIELDS.effects.element.level.label" }}</label>
    <div class="form-fields range-fields">
        {{ formInput fields.level.fields.min name=(concat prefix "level.min") value=data.level.min
                     placeholder="0" ariaLabel=(localize "SHMN.LevelLimit.Min")
                     input=@root.inputs.createNumberInput }}
        <shmn-icon src="systems/shmn/icons/svg/range-connector.svg" class="sep"></shmn-icon>
        {{ formInput fields.level.fields.max name=(concat prefix "level.max") value=data.level.max
                     placeholder="∞" ariaLabel=(localize "SHMN.LevelLimit.Max") }}
    </div>
    <p class="hint">{{ localize "SHMN.ACTIVITY.FIELDS.effects.element.level.hint" }}</p>
</div>
